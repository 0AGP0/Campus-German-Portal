// Campus German CRM Portal - Prisma Schema
// Roller: ADMIN, CONSULTANT, STUDENT

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CONSULTANT
  STUDENT
}

// Öğrenci aşama/durum (CRM pipeline)
enum StudentStage {
  BASVURU
  BELGELER_TAMAM
  ODEME_BEKLIYOR
  KAYIT_TAMAM
}

// Kullanıcılar: admin, danışman, öğrenci
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedStudents Student[] @relation("ConsultantStudents")
  studentProfile   Student?  @relation("StudentUser")
}

model Student {
  id           String       @id @default(cuid())
  userId       String?      @unique
  consultantId String?
  stage        StudentStage @default(BASVURU)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User?      @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)
  consultant User?      @relation("ConsultantStudents", fields: [consultantId], references: [id], onDelete: SetNull)
  documents  Document[]
}

model Document {
  id         String   @id @default(cuid())
  studentId  String
  filename   String
  filepath   String
  mimeType   String?
  tag        String?
  uploadedBy String
  createdAt  DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Template {
  id           String   @id @default(cuid())
  name         String
  description  String?
  htmlPath     String
  placeholders String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
